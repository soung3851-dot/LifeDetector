{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/analyze", "destination": "/api/index.py" },
    { "source": "/health", "destination": "/api/index.py" },
    { "source": "/", "destination": "/fronted/index.html" },
    { "source": "/dashboard", "destination": "/fronted/dashboard/index.html" },
    { "source": "/dashboard/(.*)", "destination": "/fronted/dashboard/$1" },
    { "source": "/meet", "destination": "/fronted/meet/index.html" },
    { "source": "/assets/(.*)", "destination": "/fronted/assets/$1" }
  ],
  "functions": {
    "api/index.py": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
